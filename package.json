{
    "name": "cwsp-reborn",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "check:topology": "node --test test/build-topology.test.mjs",
        "check:settings-backend": "node --import ./scripts/resolve-aliases.mjs --experimental-strip-types --test test/settings-backend.test.mjs",
        "check:clipboard-backend": "node --import ./scripts/resolve-aliases.mjs --experimental-strip-types --test test/clipboard-backend.test.mjs",
        "check:protocol-facades": "node --import ./scripts/resolve-aliases.mjs --experimental-strip-types --test test/protocol-facade.test.ts",
        "check:web-backend": "node --import ./scripts/resolve-aliases.mjs --experimental-strip-types --test test/web-backend-protocol.test.ts",
        "check:ws-loopback": "bash scripts/check-ws-loopback.sh",
        "check:java-backend": "bash scripts/check-java-backend.sh",
        "check:types": "tsc --noEmit",
        "check:java-protocol": "bash scripts/check-java-protocol.sh",
        "build:capacitor:web": "vite build --mode capacitor",
        "build:capacitor": "node scripts/build-capacitor.mjs",
        "build:capacitor:apk": "node scripts/build-capacitor.mjs",
        "build:capacitor:apk:release": "node scripts/build-capacitor.mjs --release",
        "sync:capacitor:android": "node scripts/sync-capacitor-android.mjs",
        "copy:capacitor:apk": "node scripts/copy-capacitor-apk.mjs",
        "build:webnative": "vite build --mode webnative",
        "start": "node scripts/start-runtime.mjs --runtime node",
        "start:node": "node scripts/start-runtime.mjs --runtime node",
        "start:java": "node scripts/start-runtime.mjs --runtime java",
        "start:pm2": "node scripts/start-runtime.mjs --runtime pm2",
        "start:pm2:node": "node scripts/start-runtime.mjs --runtime pm2-node",
        "start:pm2:java": "node scripts/start-runtime.mjs --runtime pm2-java",
        "deploy:110": "node scripts/deploy-runtime.mjs --target 110 --runtime node && node scripts/deploy-runtime.mjs --target 110 --runtime java",
        "deploy:110:node": "node scripts/deploy-runtime.mjs --target 110 --runtime node",
        "deploy:110:java": "node scripts/deploy-runtime.mjs --target 110 --runtime java",
        "deploy:200:node": "node scripts/deploy-runtime.mjs --target 200 --runtime node",
        "deploy:200:java": "node scripts/deploy-runtime.mjs --target 200 --runtime java",
        "start:endpoint:tls": "node scripts/start-endpoint-tls.mjs",
        "start:endpoint:tls:fg": "node scripts/start-endpoint-tls.mjs --foreground",
        "status:endpoint:tls": "node scripts/start-endpoint-tls.mjs --status",
        "check:ws-live": "node scripts/check-ws-live.mjs",
        "check:ws-live:lan": "node scripts/check-ws-live.mjs --url https://192.168.0.200:8434",
        "phone:ws-e2": "node scripts/phone-ws-e2.mjs",
        "phone:ws-e2:208": "node scripts/phone-ws-e2.mjs --serial 192.168.0.208:5555 --client-id L-192.168.0.208",
        "phone:ws-e2:210": "node scripts/phone-ws-e2.mjs --serial 192.168.0.210:5555 --client-id L-192.168.0.210"
    },
    "dependencies": {
        "@capacitor/core": "^8.4.1",
        "@fest-lib/cwsp-shared": "file:../../modules/projects/cwsp-shared",
        "vite": ">=8.0.7"
    },
    "devDependencies": {
        "@capacitor/android": "^8.4.1",
        "@types/node": ">=24.7.2",
        "typescript": ">=6.0.0-beta",
        "vite": ">=8.0.7"
    }
}
