{
    "name": "cwsp-reborn",
    "version": "0.0.102",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "check:topology": "node --test test/build-topology.test.mjs",
        "check:settings-backend": "node --import ./scripts/resolve-aliases.mjs --experimental-strip-types --test test/settings-backend.test.mjs",
        "check:clipboard-backend": "node --import ./scripts/resolve-aliases.mjs --experimental-strip-types --test test/clipboard-backend.test.mjs",
        "check:protocol-facades": "node --import ./scripts/resolve-aliases.mjs --experimental-strip-types --test test/protocol-facade.test.ts",
        "check:web-backend": "node --import ./scripts/resolve-aliases.mjs --experimental-strip-types --test test/web-backend-protocol.test.ts",
        "check:ws-loopback": "bash scripts/check-ws-loopback.sh",
        "check:neutralino-focus": "node --test test/neutralino-focus.test.mjs",
        "check:java-backend": "bash scripts/check-java-backend.sh",
        "check:types": "tsc --noEmit",
        "check:java-protocol": "bash scripts/check-java-protocol.sh",
        "build:capacitor": "node scripts/build-capacitor.mjs",
        "build:capacitor:apk": "node scripts/build-capacitor.mjs",
        "build:capacitor:apk:release": "node scripts/build-capacitor.mjs --release",
        "bump:capacitor:version": "node scripts/bump-capacitor-version.mjs",
        "build:webnative": "node scripts/build-webnative.mjs",
        "build:webnative:windows": "node scripts/build-webnative.mjs --platform windows",
        "build:webnative:linux": "node scripts/build-webnative.mjs --platform linux",
        "build:windows": "node scripts/build-windows.mjs",
        "build:neutralino": "node scripts/build-neutralino.mjs",
        "build:neutralino:web": "vite build --mode neutralino --configLoader runner",
        "build:capacitor:web": "vite build --mode capacitor --configLoader runner",
        "build:webnative:web": "vite build --mode webnative --configLoader runner",
        "build:gateway:web": "vite build --mode gateway --configLoader runner && node scripts/stage-gateway-web.mjs",
        "build:cwsp-control:web": "vite build --mode cwsp-control --configLoader runner && node scripts/stage-cwsp-control-web.mjs",
        "build:neutralino:windows": "node scripts/build-neutralino.mjs --platform windows",
        "build:neutralino:linux": "node scripts/build-neutralino.mjs --platform linux",
        "build:neutralino:web-only": "node scripts/build-neutralino.mjs --web-only",
        "build:neutralino:backend": "node scripts/build-neutralino.mjs --backend-only --platform windows",
        "build:windows:windows": "node scripts/build-windows.mjs --platform windows",
        "build:windows:linux": "node scripts/build-windows.mjs --platform linux",
        "sync:capacitor:android": "node scripts/sync-capacitor-android.mjs",
        "copy:capacitor:apk": "node scripts/copy-capacitor-apk.mjs",
        "start": "node scripts/start-runtime.mjs --runtime node",
        "start:node": "node scripts/start-runtime.mjs --runtime node",
        "start:java": "node scripts/start-runtime.mjs --runtime java",
        "start:neutralino": "node scripts/start-runtime.mjs --runtime neutralino",
        "start:windows": "node scripts/start-runtime.mjs --runtime windows",
        "start:pm2": "node scripts/start-runtime.mjs --runtime pm2",
        "start:pm2:node": "node scripts/start-runtime.mjs --runtime pm2-node",
        "start:pm2:java": "node scripts/start-runtime.mjs --runtime pm2-java",
        "start:pm2:neutralino": "node scripts/start-runtime.mjs --runtime pm2-neutralino",
        "start:pm2:windows": "node scripts/start-runtime.mjs --runtime pm2-windows",
        "deploy:110": "node scripts/deploy-runtime.mjs --target 110 --runtime node && node scripts/deploy-runtime.mjs --target 110 --runtime java",
        "deploy:110:node": "node scripts/deploy-runtime.mjs --target 110 --runtime node",
        "deploy:110:java": "node scripts/deploy-runtime.mjs --target 110 --runtime java",
        "deploy:110:neutralino": "node scripts/deploy-runtime.mjs --target 110 --runtime neutralino",
        "desk:110:headless": "node scripts/desk-110-headless.mjs",
        "desk:110:headless:stop": "node scripts/desk-110-headless.mjs --stop",
        "desk:110:headless:status": "node scripts/desk-110-headless.mjs --status",
        "deploy:110:neutralino:rebuild": "node scripts/deploy-runtime.mjs --target 110 --runtime neutralino --rebuild",
        "deploy:110:windows": "node scripts/deploy-runtime.mjs --target 110 --runtime neutralino",
        "deploy:200:node": "node scripts/deploy-runtime.mjs --target 200 --runtime node",
        "deploy:200:java": "node scripts/deploy-runtime.mjs --target 200 --runtime java",
        "deploy:200:neutralino": "node scripts/deploy-runtime.mjs --target 200 --runtime neutralino",
        "deploy:200:windows": "node scripts/deploy-runtime.mjs --target 200 --runtime neutralino",
        "start:endpoint:tls": "node scripts/start-endpoint-tls.mjs",
        "start:endpoint:tls:fg": "node scripts/start-endpoint-tls.mjs --foreground",
        "status:endpoint:tls": "node scripts/start-endpoint-tls.mjs --status",
        "check:ws-live": "node scripts/check-ws-live.mjs",
        "check:ws-live:lan": "node scripts/check-ws-live.mjs --url https://192.168.0.200:8434",
        "phone:ws-e2": "node scripts/phone-ws-e2.mjs",
        "phone:ws-e2:208": "node scripts/phone-ws-e2.mjs --serial 192.168.0.208:5555 --client-id L-208",
        "phone:ws-e2:210": "node scripts/phone-ws-e2.mjs --serial 192.168.0.210:5555 --client-id L-210",
        "publish:apk": "node scripts/publish-android-apk.mjs",
        "publish:apk:200": "node scripts/publish-android-apk.mjs --remote"
    },
    "dependencies": {
        "@capacitor/android": ">=8.4.1",
        "@capacitor/core": ">=8.4.1",
        "@fest-lib/cwsp-shared": "file:../../modules/projects/cwsp-shared",
        "@neutralinojs/lib": ">=6.8.0",
        "@neutralinojs/neu": ">=11.7.2"
    },
    "devDependencies": {
        "@types/node": ">=24.7.2",
        "clipboardy": ">=5.3.1",
        "fflate": "^0.8.3",
        "gzip-size": "^7.0.0",
        "pako": "^1.0.11",
        "tar": "^7.5.20",
        "typescript": ">=7.0.2",
        "vite": ">=8.1.4",
        "vite-plugin-compression2": "^2.5.3",
        "ws": ">=8.21.1"
    }
}
