<?xml version="1.0" encoding="utf-8"?>
<!--
  Filename: AndroidManifest.xml
  FullPath: apps/CWSP-reborn/app/android/AndroidManifest.xml
  Change date and time: 18.25.00_21.07.2026
  Reason for changes: Open-with / share-target */* intent-filters on ShareActivity for files-hub Temp stage (Task 5).
  2026-07-21 (Bug A/B): register FilesPromptReceiver (exported=false) for
  outgoing-share Dismiss + inbound files:offer Accept/Decline notification actions.
  2026-07-21f: CwspFilesDocumentsProvider — SAF root "CWSP Files" for explorers.
  2026-07-21g: READ_MEDIA_* / READ_EXTERNAL_STORAGE + MANAGE_EXTERNAL_STORAGE
  (opt-in all-files via system settings; DocumentsProvider remains for our tree).
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <!-- SECURITY: never declare SMS — Play Protect / banks treat it as high-risk. -->
    <uses-permission android:name="android.permission.READ_SMS" tools:node="remove" />
    <uses-permission android:name="android.permission.RECEIVE_SMS" tools:node="remove" />
    <uses-permission android:name="android.permission.SEND_SMS" tools:node="remove" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <!-- WHY: in-app sideload of fleet/dev APK from gateway /releases/android. -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <!--
      File / shared-storage access (Capacitor files transfer).
      Runtime: READ_MEDIA_* (API 33+) or READ_EXTERNAL_STORAGE (≤32).
      Special access: MANAGE_EXTERNAL_STORAGE — user enables “Allow access to
      manage all files” in system settings (not a normal runtime dialog).
      Refs: https://developer.android.com/training/data-storage/manage-all-files
            https://developer.android.com/reference/android/Manifest.permission
      NOTE: Even with all-files, other apps' Android/data stays private; our
      own tree is exposed via DocumentsProvider (CWSP Files).
    -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28"
        tools:ignore="ScopedStorage" />
    <uses-permission
        android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:usesCleartextTraffic="${cwspAllowCleartext}"
        android:networkSecurityConfig="@xml/network_security_config"
        android:theme="@style/AppTheme"
        tools:targetApi="34">

        <activity
            android:name="space.u2re.cwsp.MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:exported="true"
            android:launchMode="singleTask"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- E2 / automation: am start -a space.u2re.cwsp.CONFIGURE -->
            <intent-filter>
                <action android:name="space.u2re.cwsp.CONFIGURE" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- WHY: share must not open Capacitor WebView — transient overlay only.
             INVARIANT: launchMode=standard — singleInstance can drop PROCESS_TEXT extras. -->
        <activity
            android:name="space.u2re.cwsp.ShareActivity"
            android:label="@string/app_name"
            android:theme="@style/AppTheme.ShareOverlay"
            android:exported="true"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:launchMode="standard">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="image/*" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND_MULTIPLE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="image/*" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.PROCESS_TEXT" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.PROCESS_TEXT" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/*" />
            </intent-filter>
            <!-- Open / share any file into CWSP files-hub (Amendment A2).
                 WHY: VIEW (open-with) and SEND/SEND_MULTIPLE of arbitrary MIME
                 stage into app-private Temp (files/outgoing/<transferId>) and
                 emit cwspFilesIngress; text/plain + small image/* still take the
                 clipboard path above. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:mimeType="*/*" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="*/*" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND_MULTIPLE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="*/*" />
            </intent-filter>
        </activity>

        <service
            android:name="space.u2re.cwsp.CwspBridgeService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="CWSP clipboard sync and bridge keepalive" />
        </service>

        <!-- WHY: files Accept must outlive BroadcastReceiver goAsync (~10s) or
             the notif stays stuck on Accepting… (L-196 / large HTTP pull). -->
        <service
            android:name="space.u2re.cwsp.FilesAcceptService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="CWSP files Accept download and landing" />
        </service>

        <!-- WHY: Accept/Undo/Share/Erase need a brief foreground Activity so
             ClipboardManager.setPrimaryClip is allowed (Android 10+). Dismiss
             stays on ClipboardPromptReceiver (no OS write). -->
        <activity
            android:name="space.u2re.cwsp.ClipboardPromptActivity"
            android:theme="@style/AppTheme.ShareOverlay"
            android:exported="false"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:launchMode="singleTask"
            android:noHistory="true" />

        <!-- WHY: Control pairing Accept/Deny (+ dialog when notifications disabled). -->
        <activity
            android:name="space.u2re.cwsp.ControlPairActivity"
            android:theme="@style/AppTheme.ShareOverlay"
            android:exported="false"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:launchMode="singleTask"
            android:noHistory="true" />

        <!-- WHY: phase-2 clipboard prompt notification actions (Accept/Dismiss/
             Undo/Share/Erase) are delivered as broadcasts to this receiver, which
             delegates to CwspBridgeService. exported=false — app-internal only.
             Accept/Undo/Share/Erase also have Activity PendingIntents; receiver
             remains for Dismiss and compatibility. -->
        <receiver
            android:name="space.u2re.cwsp.ClipboardPromptReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="space.u2re.cwsp.CLIPBOARD_ACCEPT" />
                <action android:name="space.u2re.cwsp.CLIPBOARD_DISMISS" />
                <action android:name="space.u2re.cwsp.CLIPBOARD_UNDO" />
                <action android:name="space.u2re.cwsp.CLIPBOARD_SHARE" />
                <action android:name="space.u2re.cwsp.CLIPBOARD_ERASE" />
                <action android:name="space.u2re.cwsp.CLIPBOARD_DOWNLOAD" />
            </intent-filter>
        </receiver>

        <receiver
            android:name="space.u2re.cwsp.ControlPairReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="space.u2re.cwsp.CONTROL_PAIR_ACCEPT" />
                <action android:name="space.u2re.cwsp.CONTROL_PAIR_DENY" />
            </intent-filter>
        </receiver>

        <!-- WHY (Bug A/B): files prompt notification actions (outgoing-share
             Dismiss + inbound files:offer Accept/Decline) are delivered as
             broadcasts to this receiver. exported=false — app-internal only.
             Mirrors ClipboardPromptReceiver's static manifest pattern so the
             PendingIntents stay deliverable even when the OS killed the app. -->
        <receiver
            android:name="space.u2re.cwsp.FilesPromptReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="space.u2re.cwsp.FILES_INCOMING_ACCEPT" />
                <action android:name="space.u2re.cwsp.FILES_INCOMING_DECLINE" />
                <action android:name="space.u2re.cwsp.FILES_SHARE_LANDING" />
                <action android:name="space.u2re.cwsp.FILES_OPEN_LANDING" />
                <action android:name="space.u2re.cwsp.FILES_OPEN_FILE" />
                <action android:name="space.u2re.cwsp.FILES_OUTGOING_DISMISS" />
            </intent-filter>
        </receiver>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!--
          WHY: surface app-private files/ (outgoing/incoming/landing) in system
          Files / SAF explorers. App-specific storage is not browsable under
          Android/data; MANAGE_EXTERNAL_STORAGE is Play-restricted and still
          cannot open other apps' private dirs.
          Ref: https://developer.android.com/guide/topics/providers/document-provider
        -->
        <provider
            android:name="emission.CwspFilesDocumentsProvider"
            android:authorities="${applicationId}.files"
            android:exported="true"
            android:grantUriPermissions="true"
            android:permission="android.permission.MANAGE_DOCUMENTS">
            <intent-filter>
                <action android:name="android.content.action.DOCUMENTS_PROVIDER" />
            </intent-filter>
        </provider>
    </application>

</manifest>
