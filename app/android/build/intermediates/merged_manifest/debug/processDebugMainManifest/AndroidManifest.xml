<?xml version="1.0" encoding="utf-8"?>
<!--
  Filename: AndroidManifest.xml
  FullPath: apps/CWSP-reborn/app/android/AndroidManifest.xml
  Change date and time: 14.22.00_20.07.2026
  Reason for changes: REQUEST_INSTALL_PACKAGES for gateway APK sideload (app:update:*).
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="space.u2re.cwsp"
    android:versionCode="13"
    android:versionName="0.0.13" >

    <uses-sdk
        android:minSdkVersion="24"
        android:targetSdkVersion="36" />

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <!-- WHY: in-app sideload of fleet/dev APK from gateway /releases/android. -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <permission
        android:name="space.u2re.cwsp.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"
        android:protectionLevel="signature" />

    <uses-permission android:name="space.u2re.cwsp.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION" />

    <application
        android:allowBackup="false"
        android:appComponentFactory="androidx.core.app.CoreComponentFactory"
        android:debuggable="true"
        android:extractNativeLibs="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        android:usesCleartextTraffic="false" >
        <activity
            android:name="space.u2re.cwsp.MainActivity"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:exported="true"
            android:label="@string/title_activity_main"
            android:launchMode="singleTask"
            android:theme="@style/AppTheme.NoActionBarLaunch" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- E2 / automation: am start -a space.u2re.cwsp.CONFIGURE -->
            <intent-filter>
                <action android:name="space.u2re.cwsp.CONFIGURE" />

                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!--
             WHY: share must not open Capacitor WebView — transient overlay only.
             INVARIANT: launchMode=standard — singleInstance can drop PROCESS_TEXT extras.
        -->
        <activity
            android:name="space.u2re.cwsp.ShareActivity"
            android:excludeFromRecents="true"
            android:exported="true"
            android:label="@string/app_name"
            android:launchMode="standard"
            android:taskAffinity=""
            android:theme="@style/AppTheme.ShareOverlay" >
            <intent-filter>
                <action android:name="android.intent.action.SEND" />

                <category android:name="android.intent.category.DEFAULT" />

                <data android:mimeType="text/plain" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND" />

                <category android:name="android.intent.category.DEFAULT" />

                <data android:mimeType="image/*" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND_MULTIPLE" />

                <category android:name="android.intent.category.DEFAULT" />

                <data android:mimeType="image/*" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.PROCESS_TEXT" />

                <category android:name="android.intent.category.DEFAULT" />

                <data android:mimeType="text/plain" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.PROCESS_TEXT" />

                <category android:name="android.intent.category.DEFAULT" />

                <data android:mimeType="text/*" />
            </intent-filter>
        </activity>

        <service
            android:name="space.u2re.cwsp.CwspBridgeService"
            android:exported="false"
            android:foregroundServiceType="specialUse" >
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="CWSP clipboard sync and bridge keepalive" />
        </service>

        <!--
             WHY: Accept/Undo/Share/Erase need a brief foreground Activity so
             ClipboardManager.setPrimaryClip is allowed (Android 10+). Dismiss
             stays on ClipboardPromptReceiver (no OS write).
        -->
        <activity
            android:name="space.u2re.cwsp.ClipboardPromptActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:launchMode="singleTask"
            android:noHistory="true"
            android:taskAffinity=""
            android:theme="@style/AppTheme.ShareOverlay" />

        <!-- WHY: Control pairing Accept/Deny (+ dialog when notifications disabled). -->
        <activity
            android:name="space.u2re.cwsp.ControlPairActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:launchMode="singleTask"
            android:noHistory="true"
            android:taskAffinity=""
            android:theme="@style/AppTheme.ShareOverlay" />

        <!--
             WHY: phase-2 clipboard prompt notification actions (Accept/Dismiss/
             Undo/Share/Erase) are delivered as broadcasts to this receiver, which
             delegates to CwspBridgeService. exported=false — app-internal only.
             Accept/Undo/Share/Erase also have Activity PendingIntents; receiver
             remains for Dismiss and compatibility.
        -->
        <receiver
            android:name="space.u2re.cwsp.ClipboardPromptReceiver"
            android:exported="false" >
            <intent-filter>
                <action android:name="space.u2re.cwsp.CLIPBOARD_ACCEPT" />
                <action android:name="space.u2re.cwsp.CLIPBOARD_DISMISS" />
                <action android:name="space.u2re.cwsp.CLIPBOARD_UNDO" />
                <action android:name="space.u2re.cwsp.CLIPBOARD_SHARE" />
                <action android:name="space.u2re.cwsp.CLIPBOARD_ERASE" />
            </intent-filter>
        </receiver>
        <receiver
            android:name="space.u2re.cwsp.ControlPairReceiver"
            android:exported="false" >
            <intent-filter>
                <action android:name="space.u2re.cwsp.CONTROL_PAIR_ACCEPT" />
                <action android:name="space.u2re.cwsp.CONTROL_PAIR_DENY" />
            </intent-filter>
        </receiver>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="space.u2re.cwsp.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true" >
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="space.u2re.cwsp.androidx-startup"
            android:exported="false" >
            <meta-data
                android:name="androidx.emoji2.text.EmojiCompatInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.lifecycle.ProcessLifecycleInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.profileinstaller.ProfileInstallerInitializer"
                android:value="androidx.startup" />
        </provider>

        <receiver
            android:name="androidx.profileinstaller.ProfileInstallReceiver"
            android:directBootAware="false"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.DUMP" >
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.INSTALL_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SKIP_FILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SAVE_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.BENCHMARK_OPERATION" />
            </intent-filter>
        </receiver>
    </application>

</manifest>