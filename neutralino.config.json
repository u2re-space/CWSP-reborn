{
    "$schema": "https://raw.githubusercontent.com/neutralinojs/neutralinojs/main/schemas/neutralino.config.schema.json",
    "applicationId": "com.u2re.cwsp-reborn",
    "applicationName": "CWSP Reborn",
    "description": "CWSP Reborn",
    "author": "U2RE",
    "applicationIcon": "resources/icons/appIcon.png",
    "version": "1.0.0",
    "defaultMode": "window",
    "port": 18764,
    "documentRoot": "/resources/",
    "url": "/",
    "enableServer": true,
    "enableNativeAPI": true,
    "enableExtensions": true,
    "exportAuthInfo": true,
    "tokenSecurity": "one-time",
    "logging": {
        "enabled": true,
        "writeToLogFile": true
    },
    "nativeAllowList": [
        "app.*",
        "os.*",
        "debug.log",
        "window.*",
        "events.*",
        "extensions.*"
    ],
    "globalVariables": {
        "CWSP_TITLE": "CWSP Neutralino",
        "CWSP_CLIENT_ID": "L-110"
    },
    "modes": {
        "window": {
            "title": "CWSP Neutralino",
            "width": 1280,
            "height": 800,
            "minWidth": 1280,
            "minHeight": 800,
            "center": true,
            "fullScreen": false,
            "alwaysOnTop": false,
            "icon": "/resources/icons/appIcon.png",
            "enableInspector": false,
            "borderless": false,
            "maximize": false,
            "hidden": false,
            "resizable": true,
            "exitProcessOnClose": false
        },
        "browser": {
            "globalVariables": {
                "CWSP_TITLE": "CWSP Neutralino",
                "CWSP_CLIENT_ID": "L-110"
            },
            "nativeBlockList": ["filesystem.*"]
        },
        "cloud": {
            "url": "/#cloud",
            "nativeAllowList": ["app.*"]
        },
        "chrome": {
            "width": 1280,
            "height": 800,
            "args": "--user-agent=\"Neutralinojs chrome mode\"",
            "nativeBlockList": ["filesystem.*", "os.*"]
        }
    },
    "cli": {
        "binaryName": "cwsp-neutralino",
        "resourcesPath": "/resources/",
        "extensionsPath": "/extensions/",
        "clientLibrary": "/resources/js/neutralino.js",
        "icon": "/resources/icons/appIcon.ico",
        "binaryVersion": "6.2.0",
        "clientVersion": "6.2.0"
    },
    "extensions": [
        {
            "id": "extNode",
            "command": "node ${NL_PATH}/extensions/node/main.js",
            "commandDarwin": "node ${NL_PATH}/extensions/node/main.js",
            "commandLinux": "node ${NL_PATH}/extensions/node/main.js",
            "commandWindows": "C:\\PROGRA~1\\nodejs\\node.exe ${NL_PATH}\\extensions\\node\\main.js"
        }
    ]
}
